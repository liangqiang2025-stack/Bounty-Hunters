{
  "name": "bounty-hunters-api",
  "version": "2.1.0",
  "environment": "production",
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "timeout": 30000
  },
  "database": {
    "host": "db.internal.local",
    "port": 5432,
    "name": "bounty_hunters",
    "pool_size": 10,
    "ssl": true
  },
  "logging": {
    "level": "info",
    "format": "json",
    "output": "stdout"
  },
  "features": {
    "rate_limiting": true,
    "cors": true,
    "allowed_origins": ["https://app.example.com", "https://admin.example.com"],
  }
}
